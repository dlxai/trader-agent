{
  "id": "polymarket-trader",
  "name": "Polymarket Trader",
  "version": "0.2.0",
  "description": "Polymarket trading engine with OpenClaw integration",
  "entry": "packages/engine/dist/index.js",
  "capabilities": ["cron", "events", "storage"],
  "config": {
    "polymarket": {
      "wsEndpoint": "wss://ws.polymarket.com",
      "restEndpoint": "https://clob.polymarket.com"
    },
    "risk": {
      "dailyHaltThreshold": -0.02,
      "weeklyHaltThreshold": -0.04,
      "maxSingleTradeLoss": 50
    }
  },
  "agents": [
    {
      "id": "polymarket-analyzer",
      "name": "Polymarket Analyzer",
      "description": "Analyzes trading signals using LLM",
      "trigger": "onSignal"
    },
    {
      "id": "polymarket-reviewer",
      "name": "Polymarket Reviewer",
      "description": "Daily performance review and filter optimization",
      "trigger": "cron:0 0 * * *"
    },
    {
      "id": "polymarket-coordinator",
      "name": "Polymarket Coordinator",
      "description": "Hourly risk monitoring and alerts",
      "trigger": "cron:0 * * * *"
    }
  ]
}
