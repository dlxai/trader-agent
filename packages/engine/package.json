{
  "name": "@pmt/engine",
  "version": "0.2.0",
  "description": "Polymarket trading engine — collector, executor, repos, rules (OpenClaw Plugin)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "id": "polymarket-trader",
    "name": "Polymarket Trader",
    "version": "0.2.0",
    "entry": "./dist/index.js",
    "capabilities": ["cron", "events", "storage"],
    "config": {
      "polymarket": {
        "wsEndpoint": "wss://ws.polymarket.com",
        "restEndpoint": "https://clob.polymarket.com"
      },
      "risk": {
        "dailyHaltThreshold": -0.02,
        "weeklyHaltThreshold": -0.04,
        "maxSingleTradeLoss": 50
      }
    },
    "agents": [
      {
        "id": "polymarket-analyzer",
        "name": "Polymarket Analyzer",
        "description": "Analyzes trading signals using LLM",
        "trigger": "onSignal"
      },
      {
        "id": "polymarket-reviewer",
        "name": "Polymarket Reviewer",
        "description": "Daily performance review and filter optimization",
        "trigger": "cron:0 0 * * *"
      },
      {
        "id": "polymarket-coordinator",
        "name": "Polymarket Coordinator",
        "description": "Hourly risk monitoring and alerts",
        "trigger": "cron:0 * * * *"
      }
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collector": {
      "types": "./dist/collector/index.d.ts",
      "import": "./dist/collector/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "import": "./dist/executor/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./bus": {
      "types": "./dist/bus/index.d.ts",
      "import": "./dist/bus/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./reviewer": {
      "types": "./dist/reviewer/index.d.ts",
      "import": "./dist/reviewer/index.js"
    },
    "./recovery": {
      "types": "./dist/recovery/index.d.ts",
      "import": "./dist/recovery/index.js"
    },
    "./analyzer": {
      "types": "./dist/analyzer/index.d.ts",
      "import": "./dist/analyzer/index.js"
    },
    "./util": {
      "types": "./dist/util/index.d.ts",
      "import": "./dist/util/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/ws": "^8.5.12",
    "tsdown": "^0.20.3",
    "vitest": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2"
  }
}
