{
  "name": "@pmt/main",
  "version": "0.2.0",
  "description": "Electron main process for Polymarket Trader Desktop",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "electron dist/index.js",
    "start:mock": "set MOCK_DATA=true && electron dist/index.js",
    "electron:dev": "NODE_ENV=development electron dist/index.js",
    "electron:dev:win": "set NODE_ENV=development && electron dist/index.js",
    "electron:dev:mock": "set NODE_ENV=development && set MOCK_DATA=true && electron dist/index.js"
  },
  "dependencies": {
    "@pmt/engine": "workspace:*",
    "@pmt/llm": "workspace:*",
    "@polymarket/clob-client-v2": "^0.2.6",
    "viem": "^2.47.12"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "tsdown": "^0.20.3",
    "vitest": "^4.1.2"
  }
}
