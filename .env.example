# =============================================================================
# WestGardeng AutoTrader - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# Backend Configuration
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Node environment (development | production | test)
NODE_ENV=development

# API base URL (for frontend configuration)
API_URL=http://localhost:3001

# =============================================================================
# Database Configuration (SQLite with better-sqlite3)
# =============================================================================

# Database file path (relative to backend package)
DATABASE_PATH=./data/autotrader.db

# Enable WAL mode for better concurrency (true | false)
DATABASE_WAL=true

# =============================================================================
# Authentication (JWT)
# =============================================================================

# JWT secret key (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration (e.g., 1d, 12h, 7d)
JWT_EXPIRES_IN=1d

# JWT refresh token expiration
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Frontend Configuration
# =============================================================================

# Vite environment variables (must start with VITE_)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_APP_NAME=WestGardeng AutoTrader
VITE_APP_VERSION=0.3.0

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated, or * for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per window per IP
RATE_LIMIT_MAX=100

# Time window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# Logging
# =============================================================================

# Log level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# Enable pretty printing (true | false)
LOG_PRETTY=true

# =============================================================================
# WebSocket Configuration
# =============================================================================

# WebSocket ping interval in milliseconds
WS_PING_INTERVAL=30000

# WebSocket ping timeout in milliseconds
WS_PING_TIMEOUT=10000

# =============================================================================
# Trading Configuration
# =============================================================================

# Default trading mode (paper | live)
DEFAULT_TRADING_MODE=paper

# Maximum allowed leverage
MAX_LEVERAGE=10

# Enable risk management (true | false)
RISK_MANAGEMENT_ENABLED=true

# =============================================================================
# External Services (Optional)
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Datadog API key
DATADOG_API_KEY=

# Stripe API key (if using payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Docker network name
DOCKER_NETWORK=jmwl-autotrader

# Volume mount paths (for Docker)
DATA_VOLUME=./data
LOGS_VOLUME=./logs
