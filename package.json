{
  "name": "polymarket-trader",
  "private": true,
  "version": "0.2.0",
  "description": "Standalone Polymarket trading desktop application",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "postinstall": "electron-builder install-app-deps",
    "dev": "pnpm --filter @pmt/renderer dev",
    "start": "pnpm build && pnpm --filter @pmt/main start",
    "electron:dev": "pnpm --filter @pmt/main electron:dev",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:linux": "pnpm build && electron-builder --linux"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.10.5",
    "electron-builder": "^25.1.8",
    "electron": "^30.0.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
